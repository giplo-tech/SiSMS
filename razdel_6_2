%% Расчет спектральной эффективности
clear all; clc;

r = 1/2;  % кодовая скорость

M_16 = 16;
M_64 = 64;

Sef_16 = r * log2(M_16);  % для 16-QAM
Sef_64 = r * log2(M_64);  % для 64-QAM

fprintf('Спектральная эффективность:\n');
fprintf('16-QAM: S_ef = %.2f бит/с/Гц\n', Sef_16);
fprintf('64-QAM: S_ef = %.2f бит/с/Гц\n', Sef_64);
