%% Оценка вычислительной сложности
clear all; clc;

% Сложность демодуляции
demod_16 = 2;  % 16-QAM
demod_64 = 4;  % 64-QAM

% Сложность декодирования
decoding = 3;  % для кода r=1/2

% Общая сложность
total_16 = demod_16 + decoding;
total_64 = demod_64 + decoding;

fprintf('Вычислительная сложность:\n');
fprintf('16-QAM с кодированием: %d баллов\n', total_16);
fprintf('64-QAM с кодированием: %d баллов\n', total_64);
