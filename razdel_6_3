%% Расчет пропускной способности
clear all; clc;

B = 10e6;  % полоса 10 МГц
r = 1/2;

M_16 = 16;
M_64 = 64;

Sef_16 = r * log2(M_16);
Sef_64 = r * log2(M_64);

C_16 = Sef_16 * B / 1e6;  % в Мбит/с
C_64 = Sef_64 * B / 1e6;  % в Мбит/с

fprintf('Пропускная способность:\n');
fprintf('16-QAM: C = %.0f Мбит/с\n', C_16);
fprintf('64-QAM: C = %.0f Мбит/с\n', C_64);
