%% Финальный анализ выбора режима
clear all; clc;

% Данные из предыдущих разделов
SNR_16 = 11.2;  % SNR для BER=1e-4, 16-QAM с кодом
SNR_64 = 16.1;  % SNR для BER=1e-4, 64-QAM с кодом
Sef_16 = 2;     % спектральная эффективность 16-QAM
Sef_64 = 3;     % спектральная эффективность 64-QAM
C_16 = 20;      % пропускная способность, Мбит/с
C_64 = 30;      % пропускная способность, Мбит/с
complexity_16 = 5;  % сложность 16-QAM
complexity_64 = 7;  % сложность 64-QAM

% Измеренный SINR из NetMonitor
SINR_good = 18;  % хороший канал
SINR_bad = 6;    % плохой канал

% Анализ для хорошего канала
fprintf('=== ФИНАЛЬНЫЙ АНАЛИЗ ===\n\n');
fprintf('ХОРОШИЙ КАНАЛ (SINR = %d дБ):\n', SINR_good);

if SINR_good >= SNR_64
    fprintf('✓ Возможно использование 64-QAM\n');
    fprintf('  - Скорость: %d Мбит/с\n', C_64);
    fprintf('  - Сложность: %d баллов\n', complexity_64);
    fprintf('  - Помехоустойчивость: достаточная\n');
    fprintf('\nРЕКОМЕНДАЦИЯ: 64-QAM, r=1/2\n');
    fprintf('Обеспечивает максимальную скорость при достаточном качестве\n');
elseif SINR_good >= SNR_16
    fprintf('✓ Возможно использование только 16-QAM\n');
    fprintf('  - Скорость: %d Мбит/с\n', C_16);
    fprintf('  - Сложность: %d баллов\n', complexity_16);
    fprintf('  - Помехоустойчивость: хорошая\n');
    fprintf('\nРЕКОМЕНДАЦИЯ: 16-QAM, r=1/2\n');
    fprintf('64-QAM требует более высокого SINR\n');
else
    fprintf('✗ Канал слишком плохой для обоих режимов\n');
end

% Анализ для плохого канала
fprintf('\nПЛОХОЙ КАНАЛ (SINR = %d дБ):\n', SINR_bad);

if SINR_bad >= SNR_64
    fprintf('✓ Возможно использование 64-QAM\n');
    fprintf('РЕКОМЕНДАЦИЯ: 64-QAM, r=1/2\n');
elseif SINR_bad >= SNR_16
    fprintf('✓ Возможно использование 16-QAM\n');
    fprintf('  - Скорость: %d Мбит/с\n', C_16);
    fprintf('  - Сложность: %d баллов\n', complexity_16);
    fprintf('\nРЕКОМЕНДАЦИЯ: 16-QAM, r=1/2\n');
    fprintf('Обеспечивает надежную связь в плохих условиях\n');
else
    fprintf('✗ Оба режима не работают при таком SINR\n');
    fprintf('РЕКОМЕНДАЦИЯ: снизить скорость кодирования или перейти на QPSK\n');
end
